<!DOCTYPE html>
<html lang="zh-TW">

<head>
    <meta charset="UTF-8">
    <meta name="viewport"
        content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>EdgeRail | Professional EMU Simulator</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Outfit:wght@300;400;600;800&family=JetBrains+Mono:wght@500&display=swap"
        rel="stylesheet">
    <style>
        :root {
            --bg-dark: #020408;
            --panel-bg: rgba(10, 15, 25, 0.85);
            --accent: #00e5ff;
            --accent-glow: rgba(0, 229, 255, 0.5);
            --danger: #ff2d55;
            --warning: #ffb300;
            --success: #00ffa3;
            --text-main: #ffffff;
            --text-dim: rgba(255, 255, 255, 0.6);
            --glass-border: rgba(255, 255, 255, 0.1);
            --font-main: 'Outfit', sans-serif;
            --font-ui: 'Orbitron', sans-serif;
            --font-mono: 'JetBrains Mono', monospace;
        }

        * {
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        body,
        html {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            background-color: var(--bg-dark);
            overflow: hidden;
            font-family: var(--font-main);
            color: var(--text-main);
            user-select: none;
            -webkit-user-select: none;
        }

        /* Landscape Enforcement */
        #landscape-msg {
            position: fixed;
            inset: 0;
            background: var(--bg-dark);
            z-index: 10000;
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 2rem;
        }

        @media screen and (orientation: portrait) {
            #landscape-msg {
                display: flex;
            }
        }

        .phone-icon {
            font-size: 4rem;
            margin-bottom: 1.5rem;
            animation: rotatePhone 2.5s infinite ease-in-out;
        }

        @keyframes rotatePhone {
            0% {
                transform: rotate(0deg);
            }

            30% {
                transform: rotate(90deg);
            }

            70% {
                transform: rotate(90deg);
            }

            100% {
                transform: rotate(0deg);
            }
        }

        /* Visual Layers */
        #visual-player-container {
            position: fixed;
            inset: 0;
            width: 100vw;
            height: 100vh;
            z-index: 1;
            pointer-events: none;
            overflow: hidden;
        }

        #visual-player-container iframe {
            width: 100vw;
            height: 100vh;
            object-fit: cover;
        }

        #audio-player-container {
            position: absolute;
            top: -9999px;
            left: -9999px;
        }

        .overlay-layer {
            position: absolute;
            inset: 0;
            z-index: 10;
            background: radial-gradient(circle at center, transparent 50%, rgba(0, 0, 0, 0.15) 100%);
            pointer-events: none;
        }

        /* HUD - Top Bar */
        #top-hud {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 50px;
            background: linear-gradient(to bottom, rgba(0, 0, 0, 0.9), transparent);
            display: flex;
            align-items: center;
            padding: 0 24px;
            z-index: 100;
            pointer-events: auto;
        }

        .hud-status {
            display: flex;
            align-items: center;
            gap: 12px;
            font-family: var(--font-ui);
            font-size: 12px;
            letter-spacing: 2px;
        }

        .ai-pulse {
            width: 8px;
            height: 8px;
            background: var(--accent);
            border-radius: 50%;
            position: relative;
        }

        .ai-pulse::after {
            content: '';
            position: absolute;
            inset: -4px;
            border: 1px solid var(--accent);
            border-radius: 50%;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0% {
                transform: scale(1);
                opacity: 1;
            }

            100% {
                transform: scale(2.5);
                opacity: 0;
            }
        }

        .status-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: var(--success);
            box-shadow: 0 0 10px var(--success);
            animation: blink 1.5s infinite;
        }

        @keyframes blink {
            50% {
                opacity: 0.3;
            }
        }

        #clock {
            margin-left: auto;
            font-family: var(--font-mono);
            font-size: 14px;
            color: var(--accent);
            background: rgba(0, 229, 255, 0.1);
            padding: 4px 12px;
            border-radius: 4px;
            border: 1px solid rgba(0, 229, 255, 0.2);
        }

        /* Center HUD - Station Info */
        #station-display {
            position: absolute;
            top: 60px;
            left: 50%;
            transform: translateX(-50%);
            text-align: center;
            z-index: 20;
            min-width: 380px;
            pointer-events: auto;
        }

        .glass-card {
            background: var(--panel-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: 16px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
        }

        #stn-name {
            font-family: var(--font-ui);
            font-size: 36px;
            font-weight: 900;
            text-shadow: 0 0 20px var(--accent-glow);
            margin-bottom: 4px;
            text-transform: uppercase;
        }

        #stn-meta {
            font-family: var(--font-mono);
            font-size: 14px;
            color: var(--accent);
            opacity: 0.9;
        }

        /* Bottom Controls - Speedometer */
        #speed-hud {
            position: absolute;
            bottom: 40px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            align-items: flex-end;
            gap: 40px;
            z-index: 30;
        }

        #speedometer {
            text-align: center;
        }

        #speed-value {
            font-family: var(--font-ui);
            font-size: 96px;
            font-weight: 800;
            line-height: 0.9;
            color: #fff;
            text-shadow: 0 0 30px var(--accent-glow);
            font-variant-numeric: tabular-nums;
        }

        .speed-unit {
            font-size: 14px;
            font-weight: 800;
            opacity: 0.4;
            letter-spacing: 6px;
            margin-top: 5px;
        }

        /* Mascon V4 - Right Edge */
        #mascon-container {
            position: absolute;
            right: 40px;
            bottom: 40px;
            width: 120px;
            height: 400px;
            display: flex;
            flex-direction: column;
            align-items: center;
            z-index: 40;
            background: var(--panel-bg);
            backdrop-filter: blur(15px);
            border: 1px solid var(--glass-border);
            border-radius: 60px;
            padding: 20px 0;
            box-shadow: -10px 10px 30px rgba(0, 0, 0, 0.6);
        }

        #gear-label {
            font-family: var(--font-ui);
            font-size: 42px;
            font-weight: 900;
            margin-bottom: 20px;
            transition: color 0.2s;
        }

        #mascon-track {
            flex: 1;
            width: 8px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 4px;
            position: relative;
            margin: 10px 0;
        }

        #mascon-handle {
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            width: 88px;
            height: 48px;
            background: linear-gradient(135deg, #eee 0%, #999 100%);
            border-radius: 8px;
            cursor: move;
            box-shadow: 0 12px 24px rgba(0, 0, 0, 0.8);
            border: 2px solid rgba(255, 255, 255, 0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #000;
            font-weight: 900;
            font-size: 18px;
            transition: top 0.15s cubic-bezier(0.23, 1, 0.32, 1);
            touch-action: none;
        }

        #mascon-handle::after {
            content: '';
            position: absolute;
            width: 40px;
            height: 4px;
            background: rgba(0, 0, 0, 0.1);
            border-radius: 2px;
        }

        /* Door Indicator */
        #door-hud {
            position: absolute;
            top: 60px;
            right: 40px;
            padding: 12px 24px;
            font-family: var(--font-ui);
            font-size: 14px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 2px;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            z-index: 30;
        }

        .door-open {
            color: var(--success);
            border-color: var(--success) !important;
            box-shadow: 0 0 20px rgba(0, 255, 163, 0.2);
            background: rgba(0, 255, 163, 0.05);
        }

        .door-closed {
            color: var(--danger);
            border-color: var(--danger);
            background: rgba(255, 45, 85, 0.05);
        }

        /* Side Navigation */
        #side-panels {
            position: absolute;
            left: 30px;
            bottom: 40px;
            display: flex;
            flex-direction: column;
            gap: 20px;
            z-index: 50;
        }

        .ctrl-btn {
            width: 64px;
            height: 64px;
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            cursor: pointer;
            transition: all 0.2s cubic-bezier(0.18, 0.89, 0.32, 1.28);
            pointer-events: auto;
            position: relative;
        }

        .ctrl-btn:hover {
            transform: scale(1.1) translateY(-5px);
            background: rgba(255, 255, 255, 0.15);
        }

        .ctrl-btn:active {
            transform: scale(0.95);
        }

        .btn-primary {
            background: var(--accent);
            color: #000;
            font-weight: 900;
            box-shadow: 0 0 20px var(--accent-glow);
        }

        /* Floating Modals */
        .modal {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 500px;
            max-width: 90vw;
            max-height: 80vh;
            padding: 32px;
            display: none;
            z-index: 1000;
            overflow-y: auto;
            pointer-events: auto;
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            border-bottom: 1px solid var(--glass-border);
            padding-bottom: 16px;
        }

        .h-title {
            font-family: var(--font-ui);
            font-size: 20px;
            color: var(--accent);
            margin: 0;
        }

        .close-modal {
            background: none;
            border: none;
            color: var(--text-dim);
            font-size: 24px;
            cursor: pointer;
        }

        /* Startup Screen */
        #startup-layer {
            position: fixed;
            inset: 0;
            background: var(--bg-dark);
            z-index: 10000;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            transition: opacity 0.8s ease-out;
        }

        .logo-v {
            font-family: var(--font-ui);
            font-size: 48px;
            letter-spacing: -2px;
            margin-bottom: 10px;
            background: linear-gradient(to right, #fff, var(--accent));
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .launch-btn {
            background: #fff;
            color: #000;
            padding: 20px 60px;
            border-radius: 4px;
            font-family: var(--font-ui);
            font-weight: 800;
            font-size: 18px;
            border: none;
            cursor: pointer;
            margin-top: 40px;
            transition: 0.3s;
            letter-spacing: 2px;
        }

        .launch-btn:disabled {
            opacity: 0.3;
            cursor: wait;
        }

        .launch-btn:not(:disabled):hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 40px rgba(255, 255, 255, 0.3);
        }

        /* Forms & Inputs */
        input,
        textarea {
            width: 100%;
            background: rgba(0, 0, 0, 0.5);
            border: 1px solid var(--glass-border);
            border-radius: 8px;
            color: #fff;
            padding: 14px;
            font-family: var(--font-mono);
            font-size: 13px;
            outline: none;
            transition: border-color 0.2s;
        }

        input:focus {
            border-color: var(--accent);
        }

        .form-label {
            font-size: 11px;
            color: var(--text-dim);
            font-weight: 800;
            text-transform: uppercase;
            margin-bottom: 8px;
            display: block;
        }

        .action-btn {
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid var(--glass-border);
            color: #fff;
            padding: 12px;
            border-radius: 8px;
            font-weight: 700;
            width: 100%;
            cursor: pointer;
            margin-top: 10px;
            font-size: 13px;
            transition: 0.2s;
        }

        .action-btn:hover {
            background: rgba(255, 255, 255, 0.15);
        }

        .btn-green {
            background: var(--success);
            color: #000;
            border: none;
        }

        .btn-red {
            background: rgba(255, 45, 85, 0.1);
            color: var(--danger);
            border: 1px solid var(--danger);
        }

        /* Station List */
        .stn-item {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--glass-border);
            padding: 16px;
            border-radius: 12px;
            margin-bottom: 10px;
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 15px;
            align-items: center;
        }

        .stn-info h4 {
            margin: 0 0 5px;
            font-family: var(--font-ui);
            font-size: 16px;
        }

        .stn-info p {
            margin: 0;
            font-size: 12px;
            opacity: 0.5;
            font-family: var(--font-mono);
        }

        /* Mobile Optimization */
        #mobile-touch-zones {
            position: absolute;
            inset: 0;
            z-index: 10;
            display: none;
            pointer-events: none;
        }

        @media (max-width: 1000px),
        (max-height: 600px) {
            #mobile-touch-zones {
                display: block;
            }

            #mascon-container {
                right: 20px;
                scale: 0.8;
                transform-origin: bottom right;
            }

            #side-panels {
                left: 20px;
                scale: 0.8;
                transform-origin: bottom left;
            }

            #speed-hud {
                bottom: 20px;
                gap: 20px;
            }

            #speed-value {
                font-size: 72px;
            }

            #station-display {
                min-width: 300px;
                top: 50px;
            }

            #stn-name {
                font-size: 28px;
            }
        }

        .touch-zone {
            position: absolute;
            pointer-events: auto;
            display: flex;
            align-items: center;
            justify-content: center;
            color: rgba(255, 255, 255, 0.05);
            font-family: var(--font-ui);
            font-size: 32px;
            font-weight: 900;
            background: rgba(255, 255, 255, 0.01);
            transition: background 0.1s;
        }

        .touch-zone:active {
            background: rgba(255, 255, 255, 0.05);
            color: rgba(255, 255, 255, 0.2);
        }

        .zone-left {
            left: 0;
            top: 0;
            width: 25%;
            height: 100%;
            border-right: 1px dashed rgba(255, 255, 255, 0.05);
        }

        .zone-right {
            right: 0;
            top: 0;
            width: 25%;
            height: 100%;
            border-left: 1px dashed rgba(255, 255, 255, 0.05);
        }

        .zone-top {
            left: 25%;
            top: 0;
            width: 50%;
            height: 20%;
            border-bottom: 1px dashed rgba(255, 255, 255, 0.05);
            font-size: 18px;
        }

        #eval-overlay {
            position: fixed;
            top: 30%;
            left: 50%;
            transform: translate(-50%, -50%);
            z-index: 5000;
            pointer-events: none;
            text-align: center;
            opacity: 0;
            transition: 0.5s;
        }

        .eval-grade {
            font-family: var(--font-ui);
            font-size: 80px;
            font-weight: 900;
            margin: 0;
        }

        /* AI Waveform */
        .waveform {
            display: flex;
            align-items: center;
            gap: 3px;
            height: 20px;
        }

        .wave-bar {
            width: 2px;
            height: 4px;
            background: var(--accent);
            border-radius: 1px;
            animation: wave 1s ease-in-out infinite;
        }

        @keyframes wave {

            0%,
            100% {
                height: 4px;
            }

            50% {
                height: 16px;
            }
        }

        .wave-bar:nth-child(2) {
            animation-delay: 0.1s;
        }

        .wave-bar:nth-child(3) {
            animation-delay: 0.2s;
        }

        .wave-bar:nth-child(4) {
            animation-delay: 0.3s;
        }

        .wave-bar:nth-child(5) {
            animation-delay: 0.4s;
        }

        /* Scrollbar */
        ::-webkit-scrollbar {
            width: 6px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 3px;
        }
    </style>
</head>

<body>
    <div id="landscape-msg">
        <div class="phone-icon">📱</div>
        <h2 style="font-family: var(--font-ui); color: var(--accent);">請橫向持握</h2>
        <p style="opacity: 0.6;">請旋轉您的設備以獲得最佳駕駛艙視角</p>
    </div>

    <div id="startup-layer">
        <div class="logo-v">EDGERAIL</div>
        <div style="font-family: var(--font-mono); font-size: 12px; letter-spacing: 4px; color: var(--text-dim);">
            專業電聯車模擬器 V2.5</div>
        <button id="btn-master-launch" class="launch-btn" disabled>系統初始化中...</button>
        <div id="startup-log"
            style="margin-top: 20px; font-size: 11px; font-family: var(--font-mono); color: var(--accent); opacity: 0.7;">
            CORE_ENGINE_V2.5 載入中</div>
    </div>

    <div id="visual-player-container"></div>
    <div id="audio-player-container"></div>
    <div class="overlay-layer"></div>

    <div id="hud-layer" style="display: none;">
        <div id="top-hud">
            <div class="hud-status">
                <div class="status-dot"></div>
                <span>系統上線</span>
            </div>
            <div id="clock">00:00:00</div>
        </div>

        <div id="station-display">
            <div id="stn-name">---</div>
            <div id="stn-meta">等待發車</div>
        </div>

        <div id="door-hud" class="glass-card door-closed" onclick="handleAction('ToggleDoors')"
            style="cursor: pointer; pointer-events: auto;">車門鎖定</div>

        <div id="speed-hud">
            <div id="btn-jump-prev" class="ctrl-btn glass-card" onclick="openJumpMenu(-1)">⏮</div>
            <div id="speedometer">
                <div id="speed-value">0</div>
                <div class="speed-unit">KM/H</div>
            </div>
            <div id="btn-jump-next" class="ctrl-btn glass-card" onclick="openJumpMenu(1)">⏭</div>
        </div>

        <div id="mascon-container">
            <div id="gear-label" style="color: var(--accent);">N</div>
            <div id="mascon-track">
                <div id="mascon-handle">N</div>
            </div>
            <div
                style="font-family: var(--font-mono); font-size: 8px; font-weight: 500; opacity: 0.5; margin-top: 10px;">
                MC-V4 INDUSTRIAL</div>
        </div>

        <div id="side-panels">
            <div class="ctrl-btn glass-card" id="btn-automation-toggle">🤖</div>
            <div class="ctrl-btn glass-card" id="btn-help-trigger">?</div>
            <div class="ctrl-btn glass-card" id="btn-video-config">🎞</div>
            <div class="ctrl-btn glass-card" id="btn-route-config">🗺</div>
            <div class="ctrl-btn glass-card" id="btn-quick-sync">🔄</div>
            <div class="ctrl-btn btn-primary" id="btn-pause-toggle">⏸</div>
        </div>

        <div id="automation-panel" class="modal glass-card" style="width: 320px;">
            <div class="modal-header">
                <h3 class="h-title">自動化駕駛系統</h3>
                <button class="close-modal">×</button>
            </div>
            <div style="display: flex; flex-direction: column; gap: 15px;">
                <div class="stn-item" style="grid-template-columns: 1fr auto;">
                    <span>ATO (定速巡航/自動駕駛)</span>
                    <input type="checkbox" id="chk-ato" style="width: 24px; height: 24px;">
                </div>
                <div class="stn-item" style="grid-template-columns: 1fr auto;">
                    <span>TASC (定位置停止輔助)</span>
                    <input type="checkbox" id="chk-tasc" style="width: 24px; height: 24px;" checked>
                </div>
                <div class="stn-item" style="grid-template-columns: 1fr auto;">
                    <span>AUTO DOORS (自動車門)</span>
                    <input type="checkbox" id="chk-autodoor" style="width: 24px; height: 24px;">
                </div>
                <div class="stn-item" style="grid-template-columns: 1fr auto;">
                    <span>AI VOICE (語音助理)</span>
                    <input type="checkbox" id="chk-aivoice" style="width: 24px; height: 24px;" checked
                        onchange="state.aiVoiceEnabled = this.checked">
                </div>
                <div class="stn-item" style="grid-template-columns: 1fr auto;">
                    <span>AI CHAT (隨機對話)</span>
                    <input type="checkbox" id="chk-aichat" style="width: 24px; height: 24px;" checked>
                </div>
                <p style="font-size: 10px; opacity: 0.5;">* ATO 與 TASC 需要有效的路線資料才能運作。</p>
            </div>
        </div>

        <div id="mobile-touch-zones">
            <div class="touch-zone zone-left" onclick="handleAction('KeyS')">軔機 (剎車)</div>
            <div class="touch-zone zone-top" style="display: flex; gap: 0;">
                <div style="flex: 1; height: 100%; border-right: 1px solid rgba(255,255,255,0.05);"
                    onclick="handleAction('KeyQ')">開門 [Q]</div>
                <div style="flex: 1; height: 100%;" onclick="handleAction('KeyE')">關門 [E]</div>
            </div>
            <div class="touch-zone zone-right" onclick="handleAction('KeyZ')">電門 (加速)</div>
        </div>

        <div id="ai-assistant-hud" class="glass-card"
            style="display: none; position: absolute; top: 120px; right: 40px; width: 340px; padding: 20px; border-left: 4px solid var(--accent); z-index: 80;">
            <div
                style="font-family: var(--font-ui); font-size: 12px; color: var(--accent); margin-bottom: 12px; display: flex; align-items: center; justify-content: space-between;">
                <div style="display: flex; align-items: center; gap: 8px;">
                    <div class="ai-pulse"></div>
                    <span style="letter-spacing: 2px;">EDGERAIL AI OS v4.0</span>
                </div>
                <div class="waveform">
                    <div class="wave-bar"></div>
                    <div class="wave-bar"></div>
                    <div class="wave-bar"></div>
                    <div class="wave-bar"></div>
                    <div class="wave-bar"></div>
                </div>
            </div>
            <div id="ai-message"
                style="font-size: 14px; line-height: 1.6; font-weight: 500; font-family: var(--font-main);">
                系統初始化完成，隨時準備協助駕駛。</div>
            <div id="ai-sub-msg"
                style="font-size: 10px; color: var(--text-dim); margin-top: 8px; font-family: var(--font-mono);">
                VOICE_MODULE: ONLINE | LATENCY: 24ms</div>
        </div>
    </div>

    <div id="eval-overlay">
        <div class="eval-grade">EXCELLENT</div>
        <div id="eval-detail" style="font-family: var(--font-mono); font-size: 18px;">ERROR: 0.12m</div>
    </div>

    <!-- Modals -->
    <div id="modal-route" class="modal glass-card">
        <div class="modal-header">
            <h3 class="h-title">路線資料庫</h3>
            <button class="close-modal">×</button>
        </div>
        <button class="action-btn" onclick="document.getElementById('smart-discovery').style.display='block'"
            style="margin-bottom: 20px;">+ 手動新增/探索站點</button>

        <div id="stn-list-scroll" style="max-height: 300px; overflow-y: auto; margin-bottom: 20px;">
            <!-- Stations -->
        </div>

        <div style="border-top: 1px solid var(--glass-border); padding-top: 20px;">
            <label class="form-label">批次資料交換 (JSON)</label>
            <textarea id="bulk-io" placeholder='[...] / 在此貼上或匯出資料' style="height: 100px; font-size: 10px;"></textarea>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                <button class="action-btn" onclick="importData()">匯入資料</button>
                <button class="action-btn" onclick="exportDataToClipboard()">複製到剪貼簿</button>
            </div>
            <button class="action-btn btn-green" onclick="downloadData()">下載為檔案 (.JSON)</button>
            <button class="action-btn btn-red" onclick="clearFleetData()">清除所有本機站點資料</button>
        </div>
    </div>

    <div id="modal-video" class="modal glass-card">
        <div class="modal-header">
            <h3 class="h-title">影像來源連結</h3>
            <button class="close-modal">×</button>
        </div>
        <label class="form-label">YouTube 影片網址</label>
        <input type="text" id="yt-url-input" placeholder="https://www.youtube.com/watch?v=...">
        <div id="yt-preview"
            style="display: none; margin: 20px 0; padding: 15px; background: rgba(0,0,0,0.4); border-radius: 8px;">
            <div style="font-size: 10px; opacity: 0.5; margin-bottom: 5px;">影片資訊已獲取:</div>
            <div id="yt-preview-title" style="font-weight: 800; font-size: 14px;">---</div>
        </div>
        <button class="action-btn btn-primary" id="btn-fetch-yt">讀取資料</button>
        <button class="action-btn btn-green" id="btn-apply-yt" style="display: none;">套用並同步</button>
    </div>

    <div id="modal-help" class="modal glass-card">
        <div class="modal-header">
            <h3 class="h-title">操作手冊</h3>
            <button class="close-modal">×</button>
        </div>
        <div style="font-size: 14px; line-height: 1.8;">
            <p><b>[Z]</b> 電門加速 (P1-P5)</p>
            <p><b>[S]</b> 常用軔機 (B1-B4, EB)</p>
            <p><b>[A]</b> 回到惰行 (N)</p>
            <p><b>[Q] / [E]</b> 開門 / 關門</p>
            <p><b>[SPACE]</b> 一鍵切換車門 (緊急時使用)</p>
            <p><b>[X]</b> 重新校準影音同步</p>
            <hr style="opacity: 0.1;">
            <p><b>智慧車門系統:</b> 在未知的時間點開門將觸發「站點探索」，系統會自動詢問是否將該停留點記錄為車站。之後可以開啟 ATO 與 TASC 進行全自動化駕駛。</p>
        </div>
    </div>

    <!-- Smart Discovery Toast -->
    <div id="smart-discovery" class="glass-card"
        style="display: none; position: fixed; top: 100px; left: 50%; transform: translateX(-50%); width: 340px; padding: 25px; z-index: 6000; text-align: center;">
        <h3 style="font-family: var(--font-ui); color: var(--accent); margin-bottom: 10px;">站點探索</h3>
        <p style="font-size: 12px; opacity: 0.6; margin-bottom: 20px;">系統偵測到潛在停靠站。是否記錄至資料庫？</p>
        <input type="text" id="new-stn-name" placeholder="請輸入站點名稱" style="text-align: center; font-size: 18px;">
        <div style="display: flex; gap: 10px; margin-top: 20px;">
            <button class="action-btn btn-green" onclick="memorizeLocation()">儲存</button>
            <button class="action-btn"
                onclick="document.getElementById('smart-discovery').style.display='none'">忽略</button>
        </div>
    </div>

    <!-- Jump Selection Menu -->
    <div id="jump-picker" class="modal glass-card">
        <div class="modal-header">
            <h3 id="jump-title" class="h-title">選擇跳躍目標</h3>
            <button class="close-modal">×</button>
        </div>
        <div id="jump-list" style="display: flex; flex-direction: column; gap: 10px; padding-bottom: 20px;"></div>
    </div>

    <script src="https://www.youtube.com/iframe_api"></script>
    <script>
        // --- Core Engine Configuration ---
        const CONFIG = {
            GEARS: [
                { id: 0, name: 'EB', decel: 15.0, color: '#ff2d55' },
                { id: 1, name: 'B4', decel: 8.0, color: '#ff5e3a' },
                { id: 2, name: 'B3', decel: 5.0, color: '#ff9500' },
                { id: 3, name: 'B2', decel: 3.5, color: '#ffcc00' },
                { id: 4, name: 'B1', decel: 2.0, color: '#ffea00' },
                { id: 5, name: 'N', decel: 0.15, color: '#ffffff' },
                { id: 6, name: 'P1', accel: 1.5, color: '#cdff00' },
                { id: 7, name: 'P2', accel: 2.5, color: '#00ff95' },
                { id: 8, name: 'P3', accel: 4.0, color: '#00e5ff' },
                { id: 9, name: 'P4', accel: 6.5, color: '#00b8ff' },
                { id: 10, name: 'P5', accel: 9.5, color: '#008fff' }
            ],
            PHYSICS_HZ: 5, // Logic runs every 200ms
            MAX_SPEED: 130
        };

        let state = {
            isStarted: false,
            isPaused: false,
            currentSpeed: 0,
            currentGear: 5,
            doorsOpen: false,
            videoId: 'TpxTlO68CWI',
            apiReady: false,
            playersReady: 0,
            memory: JSON.parse(localStorage.getItem('edgerail_st_v3') || '{}'),
            lastRate: 1,
            atoActive: false,
            tascActive: true,
            autoDoorActive: false,
            evalShown: false,
            scheduleOffset: 0,
            aiVoiceEnabled: true,
            isCoasting: false,
            lastAITalk: 0,
            atsAlarm: false
        };

        // Legacy Data Migration
        const legacyData = localStorage.getItem('emu_memory_v2');
        if (legacyData && !localStorage.getItem('edgerail_st_v3')) {
            localStorage.setItem('edgerail_st_v3', legacyData);
            state.memory = JSON.parse(legacyData);
        }

        let vPlayer, aPlayer;
        const sfx = {
            announce: new Audio('https://actions.google.com/sounds/v1/transportation/subway_arrival.ogg'),
            doorIn: new Audio('https://od.lk/s/OTFfMzg1ODI4MTVf/door_open.mp3'), // Generic high-quality placeholder
            doorOut: new Audio('https://od.lk/s/OTFfMzg1ODI4MTZf/door_close.mp3')
        };

        // UI Binding Utilities
        const $ = id => document.getElementById(id);
        const log = (msg, level = 'info') => {
            const colors = { info: 'var(--accent)', error: 'var(--danger)', warn: 'var(--warning)' };
            $('startup-log').textContent = msg.toUpperCase();
            $('startup-log').style.color = colors[level];
        };

        function onYouTubeIframeAPIReady() {
            state.apiReady = true;
            $('btn-master-launch').disabled = false;
            $('btn-master-launch').textContent = 'INITIALIZE COCKPIT';
            log('CORE_SYSTEM READY');
        }

        $('btn-master-launch').onclick = () => {
            document.body.requestFullscreen().catch(() => { });
            launchPlayers();
        };

        function launchPlayers() {
            const playerVars = {
                autoplay: 1, controls: 0, disablekb: 1, fs: 0,
                modestbranding: 1, rel: 0, iv_load_policy: 3, playsinline: 1
            };

            vPlayer = new YT.Player('visual-player-container', {
                width: '100%',
                height: '100%',
                videoId: state.videoId,
                playerVars,
                events: { onReady: onPlayerReady, onStateChange: onVStateChange }
            });

            aPlayer = new YT.Player('audio-player-container', {
                videoId: state.videoId,
                playerVars,
                events: { onReady: onPlayerReady }
            });
        }

        function onPlayerReady() {
            state.playersReady++;
            if (state.playersReady === 2) {
                vPlayer.mute();
                aPlayer.unMute();
                $('startup-layer').style.opacity = '0';
                setTimeout(() => {
                    $('startup-layer').style.display = 'none';
                    $('hud-layer').style.display = 'block';
                    state.isStarted = true;
                    updateMasconUI();
                    startEngineLoop();
                }, 800);
            }
        }

        function onVStateChange(e) {
            if (e.data === YT.PlayerState.ENDED) vPlayer.seekTo(0);
        }

        function startEngineLoop() {
            setInterval(() => {
                if (!state.isStarted || state.isPaused) return;

                const curTime = vPlayer.getCurrentTime();
                const vState = vPlayer.getPlayerState();

                // Clock & HUD
                $('clock').textContent = new Date().toTimeString().split(' ')[0];

                const stations = state.memory[state.videoId] || [];
                const currentStn = stations.find(s => curTime >= s.time - 3 && curTime <= (s.closeTime || s.time + 30) + 3);

                if (currentStn) {
                    $('stn-name').textContent = currentStn.name;
                    $('stn-meta').textContent = '抵達月台 / 停車中';
                    $('stn-name').style.color = 'var(--accent)';

                    if (state.currentSpeed === 0 && state.doorsOpen) {
                        const diff = Math.abs(curTime - currentStn.time);
                        if (!state.evalShown) showEvaluation(diff);
                    }
                } else {
                    state.evalShown = false;
                    const next = stations.find(s => s.time > curTime);
                    if (next) {
                        const dist = Math.max(0, Math.floor((next.time - curTime) * 16.6));
                        const etaError = (state.scheduleOffset >= 0 ? '+' : '') + state.scheduleOffset + 's';
                        $('stn-name').textContent = next.name;
                        $('stn-meta').textContent = `下一站: ${dist}m | 預計抵達: ${Math.ceil(next.time - curTime)}s | 準點率: ${etaError}`;
                        $('stn-name').style.color = '#fff';

                        if (Math.abs((next.time - curTime) - 15) < 0.25) {
                            sfx.announce.play().catch(() => { });
                            triggerAI(`即將抵達 ${next.name}。請準備減速並對準 8 節車廂位置。`, 4000);
                        }
                    } else {
                        $('stn-name').textContent = '---';
                        $('stn-meta').textContent = '行駛中 / 準備接管';
                    }
                }

                updateAutomation(curTime);
                updatePhysics();

                // ATS System
                if (state.currentSpeed > 115) {
                    if (!state.atsAlarm) {
                        state.atsAlarm = true;
                        triggerAI("🚨 ATS 警告：超速中！請立即減速至 110 以下，否則將觸發安全鎖定。", 4000);
                    }
                    if (state.currentSpeed > 125) {
                        applyGear(0);
                        triggerAI("🚨 ATS 介入：嚴重超速！強制執行 EB 緊急軔機。", 6000);
                    }
                } else {
                    state.atsAlarm = false;
                }

                // AI Flavor Chat
                if ($('chk-aichat').checked && Date.now() - state.lastAITalk > 45000 && state.currentSpeed > 40 && !currentStn) {
                    const quotes = [
                        "目前車輛狀態良好，馬達溫度正常。",
                        "今日載客量預計處於離峰時段。",
                        "提醒您，進入彎道前請注意適度降速。",
                        "系統檢測中... 所有子系統運作正常。",
                        "這段路徑的風景相當不錯，不是嗎？"
                    ];
                    triggerAI(quotes[Math.floor(Math.random() * quotes.length)], 5000);
                    state.lastAITalk = Date.now();
                }

                // Keep players in sync
                if (vState === 1 && aPlayer.getPlayerState() !== 1) aPlayer.playVideo();
                if (vState === 2 && aPlayer.getPlayerState() !== 2) aPlayer.pauseVideo();

            }, 1000 / CONFIG.PHYSICS_HZ);
        }

        function updateAutomation(curTime) {
            const stations = state.memory[state.videoId] || [];
            const next = stations.find(s => s.time > curTime);
            const current = stations.find(s => curTime >= s.time - 3 && curTime <= (s.closeTime || s.time + 30) + 3);

            // AUTO DOORS
            if ($('chk-autodoor').checked && current && !state.doorsOpen && state.currentSpeed === 0) {
                setTimeout(() => { if (state.currentSpeed === 0) openDoors(); }, 1500);
            }
            if ($('chk-autodoor').checked && current && state.doorsOpen && current.closeTime && curTime > current.closeTime) {
                closeDoors();
            }

            // AUTO DEPARTURE
            if ($('chk-ato').checked && !state.doorsOpen && state.currentGear === 5 && state.currentSpeed === 0) {
                if (!state.departTriggered) {
                    state.departTriggered = true;
                    triggerAI("AI 控制：車門已確認鎖閉，信號正常，準備發車。", 3000);
                    setTimeout(() => {
                        if (!state.doorsOpen && state.currentSpeed === 0) {
                            applyGear(7);
                            setTimeout(() => { state.departTriggered = false; }, 10000);
                        } else {
                            state.departTriggered = false;
                        }
                    }, 2000);
                }
            }

            // TASC & Speed Guard
            if ($('chk-tasc').checked && next && !state.doorsOpen) {
                const timeToStop = next.time - curTime;

                // Realistic TASC: Multi-stage braking
                if (timeToStop < 20 && state.currentSpeed > 80 && state.currentGear > 4) applyGear(4); // B1
                if (timeToStop < 15 && state.currentSpeed > 60 && state.currentGear > 3) applyGear(3); // B2
                if (timeToStop < 10 && state.currentSpeed > 40 && state.currentGear > 2) applyGear(2); // B3
                if (timeToStop < 6 && state.currentSpeed > 20 && state.currentGear > 1) applyGear(1);  // B4

                // Emergency Safety
                if (timeToStop < 4 && state.currentSpeed > 15 && state.currentGear > 0) {
                    applyGear(0);
                    if (!state.ebTriggered) {
                        state.ebTriggered = true;
                        triggerAI("❗ 緊急事件：進站速度過高！強制觸發 EB 緊急軔機以確保乘車安全。", 5000);
                        setTimeout(() => { state.ebTriggered = false; }, 5000);
                    }
                }
            }

            // ATO (Auto Pilot) Speed Control + Coasting Logic
            if ($('chk-ato').checked && !state.doorsOpen) {
                if (next) {
                    const timeDiff = next.time - curTime;
                    if (timeDiff > 25) {
                        // High speed cruise (90-110)
                        if (state.currentSpeed < 90) {
                            state.isCoasting = false;
                            const targetGear = state.currentSpeed < 40 ? 10 : 8; // P5 if slow, P3 if mid
                            if (state.currentGear < targetGear) applyGear(targetGear);
                        } else if (state.currentSpeed > 105) {
                            state.isCoasting = true;
                            if (state.currentGear !== 5) {
                                applyGear(5); // Coast in N
                                triggerAI("ATO：已達標航速。進入惰行模式（省電駕駛）。", 3000);
                            }
                        } else if (state.currentSpeed > 90 && !state.isCoasting) {
                            // Stay in P1/P2 to maintain
                            if (state.currentGear > 7) applyGear(7);
                        }
                    }
                } else {
                    // No more stations, cruise at 60
                    if (state.currentSpeed < 60 && state.currentGear < 7) applyGear(7);
                    if (state.currentSpeed > 65 && state.currentGear > 5) applyGear(5);
                }
            }
        }

        function updatePhysics() {
            const gear = CONFIG.GEARS[state.currentGear];
            let delta = (gear.accel || 0) - (gear.decel || 0);
            if (state.currentGear === 5) delta = -0.15; // Natural Friction

            state.currentSpeed += delta * (1.0 / CONFIG.PHYSICS_HZ);
            if (state.currentSpeed < 0.1) state.currentSpeed = 0;
            state.currentSpeed = Math.min(CONFIG.MAX_SPEED, state.currentSpeed);

            // Playback Rate Modification (Simulator Feeling)
            if (vPlayer.setPlaybackRate) {
                let rate = state.doorsOpen ? 1.0 : (0.6 + state.currentSpeed * 0.02);
                rate = Math.max(0.5, Math.min(2.0, Math.round(rate * 10) / 10));
                if (rate !== state.lastRate) {
                    vPlayer.setPlaybackRate(rate);
                    state.lastRate = rate;
                }
            }

            $('speed-value').textContent = Math.floor(state.currentSpeed);
            $('speed-value').style.color = gear.color;
            $('speed-value').style.textShadow = `0 0 30px ${gear.color}aa`;

            // Auto-Standby if idle
            if (state.currentSpeed === 0 && !state.doorsOpen && !state.standbyActive) {
                state.standbyTimer = setTimeout(() => {
                    vPlayer.pauseVideo(); aPlayer.pauseVideo();
                    state.standbyActive = true;
                }, 8000);
            }
        }

        function applyGear(idx) {
            state.currentGear = idx;
            if (navigator.vibrate) navigator.vibrate(15);

            if (idx > 5) { // Power gear
                clearTimeout(state.standbyTimer);
                state.standbyActive = false;
                vPlayer.playVideo(); aPlayer.playVideo();
            }
            updateMasconUI();
        }

        function updateMasconUI() {
            const handle = $('mascon-handle');
            const gear = CONFIG.GEARS[state.currentGear];
            handle.style.top = `${((10 - state.currentGear) / 10) * 100}%`;
            handle.textContent = gear.name;
            $('gear-label').textContent = gear.name;
            $('gear-label').style.color = gear.color;
        }

        function handleAction(code) {
            if (!state.isStarted || state.isPaused) return;

            if (code === 'KeyZ') {
                if (state.doorsOpen) return;
                applyGear(Math.min(10, state.currentGear + 1));
            } else if (code === 'KeyS') {
                applyGear(Math.max(0, state.currentGear - 1));
            } else if (code === 'KeyA') {
                applyGear(5);
            } else if (code === 'KeyX' || code === 'Sync') {
                aPlayer.seekTo(vPlayer.getCurrentTime(), true);
            } else if (code === 'KeyQ') {
                if (state.currentSpeed > 0 || state.doorsOpen) return;
                openDoors();
            } else if (code === 'KeyE') {
                if (!state.doorsOpen) return;
                closeDoors();
            } else if (code === 'Space' || code === 'ToggleDoors') {
                if (state.currentSpeed > 0) return;
                state.doorsOpen ? closeDoors() : openDoors();
            }
        }

        function openDoors() {
            const curTime = vPlayer.getCurrentTime();
            state.doorsOpen = true;
            sfx.doorIn.play().catch(() => { });
            const hud = $('door-hud');
            hud.className = 'glass-card door-open';
            hud.textContent = '車門開啟';
            if (state.currentGear > 5) applyGear(5);

            // Smart Discovery logic
            const stations = state.memory[state.videoId] || [];
            const existing = stations.find(s => Math.abs(s.time - curTime) < 40);
            if (existing) {
                existing.time = curTime;
                saveMemory();
            } else {
                $('smart-discovery').style.display = 'block';
                triggerAI("偵測到新的停靠位置。是否要要求 AI 將其加入站點資料庫？");
            }
        }

        function closeDoors() {
            const curTime = vPlayer.getCurrentTime();
            state.doorsOpen = false;
            sfx.doorOut.play().catch(() => { });
            const hud = $('door-hud');
            hud.className = 'glass-card door-closed';
            hud.textContent = '車門鎖定';

            // Update close time
            const stations = state.memory[state.videoId] || [];
            const active = stations.find(s => Math.abs(s.time - curTime) < 60);
            if (active) { active.closeTime = curTime; saveMemory(); }
        }

        // AI Assistant Core with Voice support
        function triggerAI(msg, duration = 6000) {
            const hud = $('ai-assistant-hud');
            if (!hud) return;

            $('ai-message').textContent = msg;
            hud.style.display = 'block';
            hud.style.opacity = '0';

            // Text-to-Speech
            if (state.aiVoiceEnabled && window.speechSynthesis) {
                window.speechSynthesis.cancel();
                const utterance = new SpeechSynthesisUtterance(msg);
                utterance.lang = 'zh-TW';
                utterance.rate = 1.0;
                utterance.pitch = 1.1;
                window.speechSynthesis.speak(utterance);
            }

            setTimeout(() => { hud.style.opacity = '1'; hud.style.transition = 'all 0.5s cubic-bezier(0.16, 1, 0.3, 1)'; }, 10);

            if (state.aiTimer) clearTimeout(state.aiTimer);
            state.aiTimer = setTimeout(() => {
                hud.style.opacity = '0';
                setTimeout(() => hud.style.display = 'none', 500);
            }, duration);
        }

        function saveMemory() {
            localStorage.setItem('edgerail_st_v3', JSON.stringify(state.memory));
            refreshStationList();
        }

        // Modal Helpers
        function showModal(id) { $(id).style.display = 'block'; }
        function hideModals() { document.querySelectorAll('.modal').forEach(m => m.style.display = 'none'); }

        document.querySelectorAll('.close-modal').forEach(b => {
            b.onclick = hideModals;
        });

        $('btn-route-config').onclick = () => { refreshStationList(); showModal('modal-route'); };
        $('btn-video-config').onclick = () => showModal('modal-video');
        $('btn-help-trigger').onclick = () => showModal('modal-help');
        $('btn-automation-toggle').onclick = () => showModal('automation-panel');
        $('btn-quick-sync').onclick = () => handleAction('Sync');
        $('btn-pause-toggle').onclick = () => {
            state.isPaused = !state.isPaused;
            if (state.isPaused) { vPlayer.pauseVideo(); aPlayer.pauseVideo(); $('btn-pause-toggle').textContent = '▶'; }
            else { vPlayer.playVideo(); aPlayer.playVideo(); $('btn-pause-toggle').textContent = '⏸'; }
        };

        // Station Management
        function refreshStationList() {
            const list = $('stn-list-scroll');
            const data = state.memory[state.videoId] || [];
            if (data.length === 0) {
                list.innerHTML = '<div style="opacity:0.3;text-align:center;padding:20px;">NO ROUTE DATA IN MEMORY</div>';
                return;
            }
            list.innerHTML = data.map((s, i) => `
                <div class="stn-item" style="display: flex; flex-direction: column; align-items: stretch; gap: 8px;">
                    <div style="display: flex; gap: 10px; align-items: center;">
                        <input type="text" value="${s.name}" onchange="updateStn(${i}, 'name', this.value)" style="flex:1; font-weight:900; background:rgba(255,255,255,0.05); text-align:left;">
                        <button class="action-btn btn-red" onclick="removeStn(${i})" style="width:32px; height:32px; padding:0; border-radius:50%; margin:0;">×</button>
                    </div>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px; font-size: 11px;">
                        <div>
                            <span style="opacity:0.4; font-size:9px;">ARRIVE (S)</span>
                            <input type="number" step="0.1" value="${s.time}" onchange="updateStn(${i}, 'time', this.value)" style="height:30px; padding:4px;">
                        </div>
                        <div>
                            <span style="opacity:0.4; font-size:9px;">DEPART (S)</span>
                            <input type="number" step="0.1" value="${s.closeTime || 0}" onchange="updateStn(${i}, 'closeTime', this.value)" style="height:30px; padding:4px;">
                        </div>
                    </div>
                </div>
            `).join('');
        }

        function formatTime(s) {
            const m = Math.floor(s / 60);
            const sec = Math.floor(s % 60);
            return `${m}:${sec.toString().padStart(2, '0')}`;
        }

        window.updateStn = (i, key, val) => {
            const numVal = (key === 'name') ? val : parseFloat(val);
            state.memory[state.videoId][i][key] = numVal;
            if (key === 'time') state.memory[state.videoId].sort((a, b) => a.time - b.time);
            saveMemory();
        };

        window.removeStn = (i) => {
            state.memory[state.videoId].splice(i, 1);
            saveMemory();
        };

        window.memorizeLocation = () => {
            const name = $('new-stn-name').value.trim() || '未命名站點';
            const time = vPlayer.getCurrentTime();
            if (!state.memory[state.videoId]) state.memory[state.videoId] = [];
            state.memory[state.videoId].push({ name, time, closeTime: time + 20 });
            state.memory[state.videoId].sort((a, b) => a.time - b.time);
            saveMemory();
            $('smart-discovery').style.display = 'none';
            triggerAI(`已將【${name}】加入導航網路。AI 將自動為您計算後續到站時間。`, 4000);
        }

        // Bulk IO
        window.importData = () => {
            try {
                let raw = $('bulk-io').value.trim();
                if (!raw) return alert("輸入區為空");

                // Allow simple URL parsing if pasted alone
                if (raw.startsWith('http')) {
                    const m = raw.match(/(?:v=|\/)([0-9A-Za-z_-]{11})/);
                    if (m) { $('yt-url-input').value = raw; $('btn-fetch-yt').click(); return; }
                }

                const json = JSON.parse(raw);
                if (Array.isArray(json)) {
                    if (!state.videoId) return alert("匯入站點前請先連結影像");
                    state.memory[state.videoId] = json.map(s => ({
                        name: s.name || '未命名站點',
                        time: parseFloat(s.time) || 0,
                        closeTime: parseFloat(s.closeTime) || 0
                    })).sort((a, b) => a.time - b.time);
                    saveMemory();
                    alert("站點資料已成功注入");
                    triggerAI("資料注入完成。AI 已經獲取最新的路線導航參數。", 4000);
                } else if (typeof json === 'object') {
                    // Bulk workspace import
                    Object.assign(state.memory, json);
                    saveMemory();
                    alert("工作環境已完全恢復");
                }
            } catch (e) {
                console.error(e);
                alert("匯入失敗：資料損壞或格式錯誤");
            }
        }

        window.exportDataToClipboard = () => {
            const data = state.memory[state.videoId] || [];
            const str = JSON.stringify(data, null, 2);
            navigator.clipboard.writeText(str);
            $('bulk-io').value = str;
        }

        window.downloadData = () => {
            const data = state.memory[state.videoId] || [];
            if (data.length === 0) return alert("無資料可供匯出");
            const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `route_${state.videoId}_${Date.now()}.json`;
            a.click();
            URL.revokeObjectURL(url);
        }

        window.clearFleetData = () => {
            if (confirm("警告：確定要清除此影片的所有站點資料？此操作無法還原。")) {
                state.memory[state.videoId] = [];
                saveMemory();
                triggerAI("記憶體已抹除。目前無導航參數可以輔助。", 4000);
            }
        }

        // Video Switching
        let pendingVid = null;
        $('btn-fetch-yt').onclick = async () => {
            const url = $('yt-url-input').value;
            const m = url.match(/(?:v=|\/)([0-9A-Za-z_-]{11})/);
            if (!m) return alert("無效的網址");

            $('btn-fetch-yt').textContent = '獲取中...';
            try {
                const res = await fetch(`https://www.youtube.com/oembed?url=https://www.youtube.com/watch?v=${m[1]}&format=json`);
                const data = await res.json();
                pendingVid = m[1];
                $('yt-preview-title').textContent = data.title;
                $('yt-preview').style.display = 'block';
                $('btn-apply-yt').style.display = 'block';
                $('btn-fetch-yt').style.display = 'none';
            } catch (e) { alert("獲取失敗"); $('btn-fetch-yt').textContent = '獲取詮釋資料'; }
        };

        $('btn-apply-yt').onclick = () => {
            state.videoId = pendingVid;
            vPlayer.loadVideoById(state.videoId);
            aPlayer.loadVideoById(state.videoId);
            state.currentSpeed = 0;
            applyGear(5);
            hideModals();
            refreshStationList();
        };

        // Evaluation
        function showEvaluation(diff) {
            state.evalShown = true;
            const overlay = $('eval-overlay');
            const grade = overlay.querySelector('.eval-grade');
            const dist = (diff * 16.6).toFixed(1);

            let text = '不佳', color = 'var(--danger)', comment = "";
            if (diff < 0.3) {
                text = '完美'; color = 'gold';
                comment = "極致的控制力！誤差不到 30 釐米，乘客完全感覺不到晃動。";
            }
            else if (diff < 1.0) {
                text = '優秀'; color = 'var(--success)';
                comment = "相當準確的停靠。繼續保持這種穩定的煞車曲線。";
            }
            else if (diff < 3.0) {
                text = '良好'; color = 'var(--accent)';
                comment = "安全停靠，但仍有進步空間。建議提早進入 B1 階段。";
            } else {
                comment = "停車誤差較大。請注意 TASC 系統的建議減速點。";
            }

            triggerAI(`【到站評測】${text}！${comment}`);

            grade.textContent = text; grade.style.color = color;
            $('eval-detail').textContent = `誤差: ${dist}m (${diff.toFixed(2)}s)`;
            overlay.style.opacity = '1';
            setTimeout(() => { overlay.style.opacity = '0'; }, 3500);
        }

        // Jump Menu
        window.openJumpMenu = (dir) => {
            const time = vPlayer.getCurrentTime();
            const stations = state.memory[state.videoId] || [];
            let filtered = [];

            if (dir > 0) {
                $('jump-title').textContent = '下一站';
                filtered = stations.filter(s => s.time > time + 5);
            } else {
                $('jump-title').textContent = '上一站';
                filtered = [...stations].filter(s => s.time < time - 5).reverse();
            }

            const list = $('jump-list');
            if (filtered.length === 0) list.innerHTML = '<p style="opacity:0.3;text-align:center;">空</p>';
            else {
                list.innerHTML = filtered.map(s => `
                    <button class="action-btn" onclick="executeJump(${s.time})">
                        ${s.name} <span style="float:right;opacity:0.5;">${formatTime(s.time)}</span>
                    </button>
                `).join('');
            }
            showModal('jump-picker');
        }

        window.executeJump = (t) => {
            vPlayer.seekTo(t, true);
            aPlayer.seekTo(t, true);
            state.currentSpeed = 0;
            applyGear(5);
            hideModals();
        }

        // Touch Interaction
        const track = $('mascon-track');
        const handleDrag = (e) => {
            const rect = track.getBoundingClientRect();
            const y = (e.touches ? e.touches[0].clientY : e.clientY) - rect.top;
            const percent = Math.max(0, Math.min(1, y / rect.height));
            applyGear(10 - Math.round(percent * 10));
        };

        $('mascon-handle').addEventListener('touchstart', (e) => {
            window.addEventListener('touchmove', handleDrag);
            window.addEventListener('touchend', () => window.removeEventListener('touchmove', handleDrag), { once: true });
        });
        $('mascon-handle').addEventListener('mousedown', (e) => {
            window.addEventListener('mousemove', handleDrag);
            window.addEventListener('mouseup', () => window.removeEventListener('mousemove', handleDrag), { once: true });
        });

        // Key Listeners
        window.addEventListener('keydown', (e) => {
            if (document.activeElement.tagName === 'INPUT' || document.activeElement.tagName === 'TEXTAREA') return;
            handleAction(e.code);
        });

    </script>
</body>

</html>